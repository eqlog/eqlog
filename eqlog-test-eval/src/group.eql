type El;

func mul(El, El) -> El;
func id() -> El;
func inv(El) -> El;

rule mul_total {
    if x: El;
    if y: El;
    then mul(x, y)!;
}
rule id_total {
    then id()!;
}
rule inv_total {
    if x: El;
    then inv(x)!;
}

rule right_to_left_associativity {
    if xy = mul(x, y);
    if x_yz = mul(x, mul(y, z));
    then mul(xy, z) = x_yz;
}
rule left_to_right_associativity {
    if yz = mul(y, z);
    if xy_z = mul(mul(x, y), z);
    then mul(x, yz) = xy_z;
}

rule right_identity {
    if t_0 = x;
    if t_1 = id();
    if to = x;
    then mul(t_0, t_1) = to;
}

rule right_inverse_0 {
    if t_0 = x;
    if t_1 = inv(x);
    if to = id();
    then mul(t_0, t_1) = to;
}
rule right_inverse_1 {
    if to = mul(x, inv(x));
    then id() = to;
}
