model Set {
    type S;

    pred is_subterminal();

    rule reflexivity_member {
        if x: S;
        then x = x;
    }

    rule is_subterminal_member_collapse {
        if is_subterminal();
        if x: S;
        if y: S;
        then x = y;
    }
}

rule reflexivity_global {
    if set: Set;
    if x: set.S;
    then x = x;
}

pred is_subterminal_set(set: Set);
rule is_subterminal_set_collapse {
    if set_0: Set;
    if set_1: Set;
    if x: set_0.S;
    if y: set_0.S;
    if is_subterminal_set(set_0);
    if set_0 = set_1;
    then x = y;
}
