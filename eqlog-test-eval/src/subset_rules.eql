type Carrier;

model Subs {
    pred element(c: Carrier); 
}

func a() -> Subs;
func b() -> Subs;

func a_b() -> Mor(Subs);

rule ab_inclusion_dom {
    if a = a();
    if a_b = a_b();
    then dom(a_b) = a;
}

rule ab_inclusion_cod {
    if b = b();
    if a_b = a_b();
    then cod(a_b) = b;
}

pred ab_element(Carrier);

rule ab_elements_rule {
    if a().element(x);
    if b().element(x);
    then ab_element(x);
}

func c() -> Subs;
pred abc_element(Carrier);

// Evaluation of this rule involves looking up a model element given a tuple in
// one of its member predicates.
rule ab_c_element_rule {
    if ab_element(x);
    if c().element(x);
    then abc_element(x);
}

func d() -> Subs;
rule a_subset_d {
    if a().element(x);
    then d().element(x);
}
