type M;
func e() -> M;
func mul(M, M) -> M;

rule right_identity {
    if t_0 = x;
    if t_1 = e();
    if to = x;
    then mul(t_0, t_1) = to;
}
rule left_identity {
    if t_0 = e();
    if t_1 = x;
    if to = x;
    then mul(t_0, t_1) = to;
}
rule left_to_right_associativity {
    if ab = mul(a, b);
    if a_bc = mul(a, mul(b, c));
    then mul(ab, c) = a_bc;
}
rule right_to_left_associativity {
    if bc = mul(b, c);
    if ab_c = mul(mul(a, b), c);
    then mul(a, bc) = ab_c;
}
